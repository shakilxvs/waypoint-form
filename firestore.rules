rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── leads collection ────────────────────────────────────────
    // Public form: anyone can CREATE a new lead (write-only, no read)
    // Admin dashboard: reads and updates come via the server-side
    // session token check; we allow all for now and lock down below.
    //
    // For production hardening: enable Firebase Auth and replace
    // "if true" with "if request.auth != null"

    match /leads/{leadId} {

      // Allow the public booking form to create new leads
      allow create: if
        request.resource.data.keys().hasAll([
          'patientId', 'name', 'phone', 'address',
          'service', 'status', 'createdAt', 'createdDate'
        ]) &&
        request.resource.data.status == 'pending' &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.phone is string &&
        request.resource.data.phone.size() > 0;

      // Admin dashboard: allow read, update, delete
      // (protected by Vercel env-var login on the client side)
      allow read, update, delete: if true;
    }
  }
}
